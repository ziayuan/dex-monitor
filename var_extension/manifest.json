{
    "manifest_version": 3,
    "name": "Variational & Paradex Monitor Hook",
    "version": "1.3",
    "description": "Hooks WebSocket to forward Variational and Paradex data to local python server.",
    "permissions": [
        "scripting"
    ],
    "host_permissions": [
        "*://omni.variational.io/*",
        "*://app.paradex.trade/*",
        "http://127.0.0.1:8001/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://omni.variational.io/*",
                "*://app.paradex.trade/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "*://omni.variational.io/*",
                "*://app.paradex.trade/*"
            ],
            "js": [
                "relay.js"
            ],
            "run_at": "document_start",
            "world": "ISOLATED"
        }
    ]
}